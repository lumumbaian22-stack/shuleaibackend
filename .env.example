# ================================
# SHULE AI PRODUCTION ENV TEMPLATE
# Backend only. Never expose secrets in frontend JS.
# ================================
NODE_ENV=production
PORT=5000

# Public origins
FRONTEND_URL=https://shuleai.live
CORS_ORIGINS=https://shuleai.live,https://lumumbaian22-stack.github.io,https://shuleaiinfo-cmd.github.io

# PostgreSQL / Render
# Render normally provides DATABASE_URL. Prefer this in production.
DATABASE_URL=postgresql://user:password@host:5432/database
DB_SSL=true
DB_POOL_MAX=25
DB_POOL_MIN=2
DB_POOL_ACQUIRE_MS=60000
DB_POOL_IDLE_MS=10000
DB_POOL_EVICT_MS=10000
DB_CONNECTION_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=60000
DB_IDLE_TX_TIMEOUT_MS=60000
DB_RETRY_MAX=3
DB_LOGGING=false
DB_BENCHMARK=false

# Local DB fallback only if DATABASE_URL is not set
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shuleai
DB_USER=postgres
DB_PASSWORD=postgres

# Auth / sessions
JWT_SECRET=replace_with_strong_64_char_random_secret
JWT_EXPIRE=30d
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
SESSION_SECRET=replace_with_strong_session_secret
SUPER_ADMIN_SECRET=replace_with_private_super_admin_secret
SUPER_ADMIN_EMAIL=super@shuleai.live
SUPER_ADMIN_PASSWORD=replace_with_private_bootstrap_password

# Runtime schema repair is OFF in production. Run migrations instead.
ALLOW_RUNTIME_SCHEMA_REPAIR=false

# Uploads / job worker
MAX_FILE_SIZE=52428800
UPLOAD_PATH=./uploads
UPLOAD_TMP_DIR=./uploads/tmp
JOB_WORKER_INTERVAL_MS=5000

# Daraja / M-Pesa Express
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=your_daraja_consumer_key
DARAJA_CONSUMER_SECRET=your_daraja_consumer_secret
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=your_daraja_passkey
DARAJA_TRANSACTION_TYPE=CustomerPayBillOnline
DARAJA_CALLBACK_URL=https://your-render-backend.onrender.com/api/payments/daraja/callback
MPESA_CALLBACK_URL=https://your-render-backend.onrender.com/api/payments/daraja/callback
REQUIRE_DARAJA_CALLBACK_FOR_FEE_COMPLETION=true
DISABLE_MOCK_PAYMENTS=true
DISABLE_DEMO_DATA=true

# AI Provider / Student AI Tutor
# DeepSeek is the active provider for now. Keep API keys backend-only in Render env vars.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_from_render_env_only
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_TOKENS=900
DEEPSEEK_TEMPERATURE=0.35

# Future Claude fallback/switch option
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5
CLAUDE_MAX_TOKENS=900

# Student AI Tutor: no free tier. Limits come from child subscription plans.
DEFAULT_SCHOOL_AI_ALERT_SUGGESTIONS_PER_MONTH=100
AI_TUTOR_MAX_INPUT_CHARS=2500
AI_TUTOR_MAX_OUTPUT_TOKENS=900

# Rate limits
DEFAULT_PAGE_LIMIT=50
MAX_PAGE_LIMIT=100
READ_RATE_LIMIT_MAX=1500
WRITE_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=40
UPLOAD_RATE_LIMIT_MAX=60
