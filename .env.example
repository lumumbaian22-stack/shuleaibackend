NODE_ENV=production
PORT=5000
FRONTEND_URL=http://shuleai.live

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shuleai
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=shuleai-super-secret-jwt-key-2024-3.14159
JWT_EXPIRE=30d
JWT_REFRESH_SECRET=your-refresh-secret-change-this

# Super Admin
SUPER_ADMIN_SECRET=SUPER_SECRET_2024
SUPER_ADMIN_EMAIL=super@shuleai.com
SUPER_ADMIN_PASSWORD=SuperAdmin123!
# File uploads
MAX_FILE_SIZE=52428800
UPLOAD_PATH=./uploads

# ============ DARAJA / M-PESA EXPRESS SANDBOX ============
# Keep these ONLY on the backend. Never expose them in frontend JS.
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=your_daraja_consumer_key
DARAJA_CONSUMER_SECRET=your_daraja_consumer_secret
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
DARAJA_TRANSACTION_TYPE=CustomerPayBillOnline
DARAJA_CALLBACK_URL=https://your-backend-url.com/api/payments/daraja/callback
# v15 scale settings
DB_POOL_MAX=25
DB_POOL_MIN=2
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000
DB_STATEMENT_TIMEOUT_MS=30000
DEFAULT_PAGE_LIMIT=50
MAX_PAGE_LIMIT=100
READ_RATE_LIMIT_MAX=1500
WRITE_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=40
UPLOAD_RATE_LIMIT_MAX=60
MAX_FILE_SIZE=52428800

# ============ CLAUDE / ANTHROPIC AI TUTOR ============
# Required for real AI tutor responses. Backend only; never expose in frontend.
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-haiku-latest
AI_TUTOR_DAILY_LIMIT=50
AI_TUTOR_MAX_INPUT_CHARS=2500
AI_TUTOR_MAX_OUTPUT_TOKENS=700

# ============ PRODUCTION SAFETY ============
REQUIRE_DARAJA_CALLBACK_FOR_FEE_COMPLETION=true
DISABLE_MOCK_PAYMENTS=true
DISABLE_DEMO_DATA=true

# Shule AI subscription/payment architecture
# School fee payments use each school's SchoolPaymentSettings record.
# Platform subscription payments use PlatformPaymentSettings or these fallback env vars.
PLATFORM_MPESA_TILL=
PLATFORM_MPESA_PAYBILL=
PLATFORM_MPESA_SHORTCODE=
PLATFORM_MPESA_ACCOUNT=SHULEAI
